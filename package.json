{
  "name": "@dyne/interfacer-client",
  "version": "0.1.0",
  "packageManager": "pnpm@9.13.1",
  "description": "TypeScript client SDK for the Interfacer ecosystem — Zenflows, DPP, Inbox, Wallet, Social",
  "license": "AGPL-3.0-or-later",
  "author": "Dyne.org foundation <foundation@dyne.org>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src/zenflows-crypto/src/*.zen"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "zenroom": "^4.0.0"
  },
  "dependencies": {
    "base64url": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typescript": "^4.0.0",
    "@graphql-codegen/typescript-operations": "^4.0.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^20.0.0",
    "cross-fetch": "^4.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "form-data": "^4.0.6",
    "prettier": "^3.0.0",
    "semantic-release": "^25.0.5",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.0.0",
    "zenroom": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/interfacerproject/interfacer-client"
  },
  "keywords": [
    "interfacer",
    "zenflows",
    "valueflows",
    "dpp",
    "digital-product-passport",
    "osh",
    "open-source-hardware"
  ]
}
